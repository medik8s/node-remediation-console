{
  "name": "node-remediation-console-plugin",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "repository": "git@github.com/medik8s/node-remediation-console.git",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn ts-node node_modules/.bin/webpack",
    "build-dev": "yarn clean && yarn ts-node node_modules/.bin/webpack",
    "start": "yarn ts-node node_modules/.bin/webpack serve",
    "start-console": "./start-console.sh",
    "i18next": "i18next \"src/**/*.{js,jsx,ts,tsx}\" [-oc] -c i18next-parser.config.js",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "lint": "eslint src && stylelint \"src/**/*.css\" --allow-empty-input",
    "http-server": "./http-server.sh dist"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.22.9",
    "@babel/preset-react": "^7.22.5",
    "@babel/preset-typescript": "^7.22.5",
    "@openshift-console/dynamic-plugin-sdk": "^4.22.0-prerelease.3",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^4.22.0-prerelease.3",
    "@openshift-console/dynamic-plugin-sdk-internal": "^4.22.0-prerelease.3",
    "@patternfly/react-core": "~6.4.2",
    "@patternfly/react-icons": "~6.4.0",
    "@patternfly/react-table": "~6.4.2",
    "@patternfly/react-tokens": "~6.4.0",
    "@types/classnames": "2.2.7",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash": "4.14.182",
    "@types/lodash-es": "^4.17.12",
    "@types/mocha": "^9.1.1",
    "@types/node": "22.x",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/semver": "^6.0.0",
    "@types/yup": "^0.29.14",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^5.2.7",
    "eslint": "^8.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.1.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "http-server": "^14.1.1",
    "i18next": "^25.8.18",
    "i18next-parser": "^9.4.0",
    "prettier": "^2.7.1",
    "prettier-stylelint": "^0.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "~16.5.8",
    "react-router": "~7.13.1",
    "sass": "^1.42.1",
    "showdown": "2.1.0",
    "style-loader": "^4.0.0",
    "stylelint": "^14.9.1",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-standard": "^26.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "consolePlugin": {
    "name": "node-remediation-console-plugin",
    "version": "0.0.0",
    "displayName": "Node Remediation Console Plugin",
    "description": "UI for Node Healthcheck Operator which enables configuration and viewing of the NodeHealthCheck CRD in the console",
    "exposedModules": {
      "nodeHealthCheckListPage": "./components/list/NodeHealthCheckListPage.tsx",
      "nodeHealthCheckCreatePage": "./components/editor/NodeHealthCheckCreatePage.tsx",
      "nodeHealthCheckEditPage": "./components/editor/NodeHealthCheckEditPage.tsx",
      "nodeHealthCheckDetailsPage": "./components/details/NodeHealthCheckDetailsPage.tsx"
    },
    "dependencies": {
      "@console/pluginAPI": ">=4.16.0-0"
    }
  },
  "dependencies": {
    "classnames": "2.x",
    "formik": "^2.1.5",
    "fuzzysearch": "1.0.x",
    "i18next": "^25.8.18",
    "js-yaml": "^3.13.1",
    "lodash-es": "^4.17.21",
    "react-linkify": "^1.0.0-alpha",
    "react-tagsinput": "3.20.x",
    "semver": "6.x",
    "yup": "^1.7.1"
  },
  "engines": {
    "node": ">=22.x"
  },
  "packageManager": "yarn@1.22.22"
}